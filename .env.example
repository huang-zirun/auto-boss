# Boss直聘招聘助手环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 浏览器配置 ====================
# ChromeDriver 路径（为空则使用系统 PATH 中的驱动）
BOSS_BROWSER_DRIVER_PATH=

# Chrome 用户数据目录（用于保持登录状态）
# 注意：请使用您自己的 Chrome 用户数据目录路径
BOSS_BROWSER_USER_DATA_DIR=

# Chrome 远程调试端口
BOSS_BROWSER_DEBUG_PORT=9222

# 是否使用无头模式
BOSS_BROWSER_HEADLESS=false

# ==================== URL 配置 ====================
# 登录页面 URL
BOSS_URL_LOGIN_URL=https://www.zhipin.com/

# 推荐牛人页面 URL
BOSS_URL_RECOMMEND_PAGE_URL=https://www.zhipin.com/web/chat/recommend

# 聊天页面 URL
BOSS_URL_CHAT_PAGE_URL=https://www.zhipin.com/web/chat/index

# ==================== 时间配置 ====================
# 等待登录超时时间（秒）
BOSS_TIMING_WAIT_LOGIN_TIMEOUT=300

# 打开登录页后等待稳定时间（秒）
BOSS_TIMING_LOGIN_PAGE_WAIT_SECONDS=3.0

# 登录状态检测轮询间隔（秒）
BOSS_TIMING_LOGIN_POLL_INTERVAL_SECONDS=2.0

# 等待候选人卡片列表加载时间（秒）
BOSS_TIMING_WAIT_CARD_LIST_SECONDS=15

# 等待弹窗加载时间（秒）
BOSS_TIMING_WAIT_MODAL_SECONDS=5

# 操作间隔最小时间（秒）
BOSS_TIMING_INTERVAL_MIN=0.1

# 操作间隔最大时间（秒）
BOSS_TIMING_INTERVAL_MAX=0.6

# ==================== 筛选配置 ====================
# 是否启用 VIP 筛选功能
BOSS_FILTER_USE_VIP_FILTERS=true

# 院校筛选条件
BOSS_FILTER_FILTER_SCHOOL=双一流院校

# 简历交换状态筛选
BOSS_FILTER_FILTER_NO_RESUME_EXCHANGE=近一个月没有

# 学历筛选条件（JSON 数组格式）
# BOSS_FILTER_FILTER_EDUCATION=["本科", "硕士", "博士"]

# ==================== 职位配置 ====================
# 目标职位列表（JSON 数组格式，为空则处理所有职位）
# BOSS_JOB_JOB_POSITIONS=["前端开发工程师", "后端开发工程师"]

# 每个岗位最多联系候选人数量
BOSS_JOB_MAX_COUNT=1000000

# ==================== 简历配置 ====================
# 简历加载超时时间（秒）
BOSS_RESUME_RESUME_LOAD_TIMEOUT=60

# 会话间最小间隔（秒）
BOSS_RESUME_RESUME_CHAT_INTERVAL_MIN=2.0

# 会话间最大间隔（秒）
BOSS_RESUME_RESUME_CHAT_INTERVAL_MAX=5.0

# 下载简历后最小间隔（秒）
BOSS_RESUME_RESUME_DOWNLOAD_INTERVAL_MIN=15.0

# 下载简历后最大间隔（秒）
BOSS_RESUME_RESUME_DOWNLOAD_INTERVAL_MAX=45.0

# 简历最大收集数量（0 表示无限制）
BOSS_RESUME_RESUME_MAX_COLLECT=0

# ==================== 其他配置 ====================
# 调试模式
BOSS_DEBUG=false

# 日志级别
BOSS_LOG_LEVEL=INFO
